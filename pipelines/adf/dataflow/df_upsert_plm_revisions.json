{
	"name": "df_upsert_plm_revisions",
	"properties": {
		"description": "Incremental UPSERT of plm_revisions staging Parquet into Delta table. Merge key: part_id + revision.",
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_ADLS_PLM_revisions_sink",
						"type": "DatasetReference"
					},
					"name": "SourceStagingParquet",
					"description": "Reads incremental Parquet written by copy_plm_revisions"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_ADLS_PLM_revisions_sink",
						"type": "DatasetReference"
					},
					"name": "SinkDeltaRevisions",
					"description": "Delta UPSERT sink at bronze/plm/revisions",
					"rejectedDataLinkedService": {
						"referenceName": "LS_ADLS_CAD_Pipeline_Status",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "AlterRowUpsert",
					"description": "Mark every incoming row as an UPSERT candidate"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'parquet') ~> SourceStagingParquet",
				"SourceStagingParquet alterRow(upsertIf(true())) ~> AlterRowUpsert",
				"AlterRowUpsert sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     vacuum: 0) ~> SinkDeltaRevisions"
			]
		}
	}
}